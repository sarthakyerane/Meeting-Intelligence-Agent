# ─── LLM Providers (fallback chain: Gemini → Groq → Ollama) ────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here          # free at console.groq.com
OLLAMA_BASE_URL=http://host.docker.internal:11434  # optional, local Ollama instance

# ─── HuggingFace (for pyannote speaker diarization) ─────────────────────────
# 1. Create account at huggingface.co
# 2. Accept terms at: hf.co/pyannote/speaker-diarization-3.1
# 3. Generate token at: hf.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# ─── MySQL ──────────────────────────────────────────────────────────────────
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=meeting_intelligence
MYSQL_USER=meeting_user
MYSQL_PASSWORD=meeting_password
MYSQL_ROOT_PASSWORD=root_password

# ─── ChromaDB ───────────────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ─── Redis (semantic cache) ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Backend ────────────────────────────────────────────────────────────────
BACKEND_URL=http://backend:8000
